# 环境变量配置示例
# 复制此文件为 .env，填入实际值，.env 文件将被 .gitignore 自动忽略

# ============ 阿里云 DashScope API 配置 ============
# 从 https://dashscope.console.aliyun.com 获取
Ali-Key=sk_xxxxxxxxxxxxxxxxxxxx
DASHSCOPE_API_KEY=sk_xxxxxxxxxxxxxxxxxxxx

# ============ DeepSeek API 配置（如果使用） ============
DEEPSEEK_API_KEY=sk_xxxxxxxxxxxxxxxxxxxx

# ============ MinIO 凭证（开发环境） ============
# 建议生产环境使用强密码
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_strong_password_here

# ============ 腾讯云 MCP 服务配置 ============
# MCP SSE 端点路径，从腾讯云 MCP 控制台获取
TENCENT_MCP_SSE_ENDPOINT=/sse/your-session-id
TENCENT_MCP_URL=https://mcp-api.tencent-cloud.com/sse/your-session-id

# ============ 文档路径 ============
# 知识库文档的本地路径或远程路径
DOCS_PATH=/path/to/your/docs

# ============ 数据库连接 ============
# Milvus 向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ============ 应用配置 ============
# 应用端口
SERVER_PORT=9900

# JWT 密钥（如启用认证）
JWT_SECRET=your-secret-key-here

# ============ 日志级别 ============
LOG_LEVEL=INFO
